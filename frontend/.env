VITE_API_HOST=http://192.168.151.158:28001/api
# VITE_API_HOST=http://127.0.0.1:28001/api
VITE_IS_JETSON=false

# QA 问答开发模式：true=返回固定提示（不调用后端），false=正常调用后端
VITE_QA_DEV_MODE=true

# 查询状态间隔（毫秒）
VITE_LOAD_DATA_INTERVAL=500
# 强制刷新间隔（毫秒），当画面状态未变化但时间超过该值时，仍然刷新文本描述
VITE_FRESH_INTERVAL=3000
# 打字机动画时长（毫秒）
VITE_TYPING_DURATION=500
